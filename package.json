{
  "name": "solidly-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for @exowpee/solidly UI component library",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "build:core": "pnpm --filter @exowpee/solidly build",
    "build:pro": "pnpm --filter @exowpee/solidly-pro build",
    "dev": "pnpm --filter doc dev",
    "lint": "eslint '**/*.{ts,tsx}' --fix",
    "lint:ci": "eslint '**/*.{ts,tsx}' --max-warnings 0",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "publish:core": "pnpm --filter @exowpee/solidly publish",
    "publish:pro": "pnpm --filter @exowpee/solidly-pro publish",
    "claude:init": "claude /project:init-project",
    "claude:audit": "claude /project:audit-component",
    "claude:docs": "claude /project:document-component",
    "claude:fix": "claude /project:fix-component"
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.57.0",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-unused-imports": "^4.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  },
  "repository": {
    "type": "git"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
