{
  "name": "@exowpee/the_rock",
  "version": "0.1.8",
  "description": "A UI component library built with SolidJS",
  "type": "module",
  "module": "./dist/index.es.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/hooks/index.es.js"
    },
    "./context": {
      "types": "./dist/src/context/index.d.ts",
      "import": "./dist/context/index.es.js"
    },
    "./helpers": {
      "types": "./dist/src/helpers/index.d.ts",
      "import": "./dist/helpers/index.es.js"
    },
    "./icons": {
      "types": "./dist/src/icons/index.d.ts",
      "import": "./dist/icons/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "serve": "vite preview",
    "lint": "eslint '**/*.{ts,tsx}' --fix",
    "lint:ci": "eslint '**/*.{ts,tsx}' --max-warnings 0",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore ."
  },
  "publishConfig": {
    "registry": "https://gitlab.com/api/v4/projects/74368170/packages/npm/",
    "access": "restricted"
  },
  "peerDependencies": {
    "@formatjs/intl": "^3.1.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@formatjs/intl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@solidjs/router": "^0.15.3",
    "@tailwindcss/vite": "^4.1.13",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.7",
    "@types/node": "^24.5.2",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-unused-imports": "^4.2.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "solid-js": "^1.9.9",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1",
    "vite": "^6.3.6",
    "vite-plugin-solid": "^2.11.8"
  },
  "dependencies": {
    "@solid-primitives/presence": "^0.1.2",
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "tailwind-merge": "^3.3.1"
  },
  "repository": {
    "type": "git"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
