{
  "name": "the_rock",
  "version": "0.0.1",
  "description": "A UI component library built with SolidJS",
  "private": true,
  "type": "module",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.es.js"
    },
    "./context": {
      "types": "./dist/context/index.d.ts",
      "import": "./dist/context/index.es.js"
    },
    "./helpers": {
      "types": "./dist/helpers/index.d.ts",
      "import": "./dist/helpers/index.es.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "vite --config dev/vite.config.ts --host",
    "dev": "vite --config dev/vite.config.ts",
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "prepublishOnly": "pnpm build",
    "serve": "vite preview",
    "lint": "eslint '**/*.{ts,tsx}' --fix",
    "lint:ci": "eslint '**/*.{ts,tsx}' --max-warnings 0",
    "format": "prettier --check --ignore-path .prettierignore .",
    "format:fix": "prettier --write --ignore-path .prettierignore ."
  },
  "publishConfig": {
    "registry": "https://gitlab.com/xxx",
    "access": "restricted"
  },
  "peerDependencies": {
    "@formatjs/intl": "^3.1.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@formatjs/intl": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@solidjs/router": "^0.15.3",
    "@tailwindcss/vite": "^4.0.7",
    "@trivago/prettier-plugin-sort-imports": "^5.2.2",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-selection": "^3.0.11",
    "@types/d3-shape": "^3.1.7",
    "@types/node": "^24.3.1",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-unused-imports": "^4.1.4",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "solid-js": "^1.9.5",
    "tailwindcss": "^4.0.7",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.6"
  },
  "dependencies": {
    "d3-scale": "^4.0.2",
    "d3-selection": "^3.0.0",
    "d3-shape": "^3.2.0",
    "floating-ui-solid": "^1.0.63",
    "solid-transition-group": "^0.3.0",
    "tailwind-merge": "^3.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/your-group/your-repo.git"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
