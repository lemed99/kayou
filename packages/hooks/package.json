{
  "name": "@exowpee/solidly-hooks",
  "version": "1.0.0",
  "description": "Utility hooks and contexts for SolidJS applications",
  "type": "module",
  "module": "./dist/index.es.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "lint": "eslint '**/*.{ts,tsx}' --fix"
  },
  "peerDependencies": {
    "@formatjs/intl": "^3.1.0",
    "solid-js": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@formatjs/intl": {
      "optional": true
    }
  },
  "devDependencies": {
    "solid-js": "^1.9.9",
    "typescript": "^5.9.2",
    "vite": "^6.3.6",
    "vite-plugin-solid": "^2.11.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exowpee/solidly"
  },
  "license": "MIT",
  "keywords": [
    "solidjs",
    "solid",
    "hooks",
    "intl",
    "mutation",
    "resource",
    "typescript"
  ]
}
