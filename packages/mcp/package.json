{
  "name": "@kayou/mcp",
  "version": "0.1.0",
  "description": "MCP server for kayou component library - provides AI-assisted access to component APIs, hooks, and icons",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "kayou-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "tsx scripts/generate-data.ts",
    "start": "node dist/index.js",
    "prepublishOnly": "pnpm run generate && pnpm run build"
  },
  "keywords": [
    "mcp",
    "kayou",
    "solidjs",
    "components",
    "ai"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "files": [
    "dist",
    "data"
  ]
}
