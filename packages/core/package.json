{
  "name": "@exowpee/solidly",
  "version": "1.0.0",
  "description": "A free, open-source UI component library built with SolidJS",
  "type": "module",
  "module": "./dist/index.es.js",
  "types": "./dist/src/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/index.es.js"
    },
    "./hooks": {
      "types": "./dist/src/hooks/index.d.ts",
      "import": "./dist/hooks/index.es.js"
    },
    "./context": {
      "types": "./dist/src/context/index.d.ts",
      "import": "./dist/context/index.es.js"
    },
    "./helpers": {
      "types": "./dist/src/helpers/index.d.ts",
      "import": "./dist/helpers/index.es.js"
    },
    "./icons": {
      "types": "./dist/src/icons/index.d.ts",
      "import": "./dist/icons/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "lint": "eslint '**/*.{ts,tsx}' --fix"
  },
  "peerDependencies": {
    "@formatjs/intl": "^3.1.0",
    "solid-js": "^1.9.0",
    "tailwindcss": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@formatjs/intl": {
      "optional": true
    }
  },
  "dependencies": {
    "@solid-primitives/presence": "^0.1.2",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "solid-js": "^1.9.9",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "vite": "^6.3.6",
    "vite-plugin-solid": "^2.11.8"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/exowpee/solidly"
  },
  "license": "MIT",
  "keywords": [
    "solidjs",
    "solid",
    "ui",
    "components",
    "tailwindcss",
    "typescript"
  ]
}
